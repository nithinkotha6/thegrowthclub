# Environment variable template — SEC-07.
# Copy to .env.local and fill in real values. Never commit real secrets.
# See docs/04_Security_and_Gap_Analysis.md §4 for the full secret inventory
# (sensitivity level + purpose of each variable).

# Supabase
NEXT_PUBLIC_SUPABASE_URL="your_supabase_url_here"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key_here"
SUPABASE_SERVICE_ROLE_KEY=

# Auth / sessions
SESSION_SECRET=a8f5f167f44f496

# Gemini AI (comma-separated pool preferred; single-key vars are fallbacks)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key_here


# WhatsApp (Green API)
GREEN_API_INSTANCE_ID="your_green_api_instance_id_here"
GREEN_API_TOKEN="your_green_api_token_here"
WHATSAPP_GROUP_ID="your_whatsapp_group_id_here"


# Web Push (PWA push notification skeleton). Generate with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Google OAuth (wearables / Google Fit sync)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# WHOOP OAuth (wearables sync)
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

# Per-user wearable refresh-token fallback (optional, secondary to the
# self-service Connect Fitbit/Connect Whoop OAuth flow). One var per member
# who instead hands you a refresh token obtained manually. Naming pattern:
#   WEARABLE_KEY_<PROVIDER>_<NICKNAME>
# <PROVIDER> is WHOOP or FITBIT; <NICKNAME> is that member's nickname,
# upper-cased with non A-Z0-9 characters stripped (e.g. WEARABLE_KEY_WHOOP_NITHIN).
# Must be a refresh token, not an access token — access tokens expire in
# ~1 hour and would silently stop syncing. Add one line per person who needs
# this fallback; there is no fixed list since it's per-member.
# WEARABLE_KEY_WHOOP_<NICKNAME>=
# WEARABLE_KEY_FITBIT_<NICKNAME>=

# Vercel Cron
CRON_SECRET="123456789"
# Public app URL (optional). If unset, the daily-whistle broadcast omits its
# dashboard-link footer line entirely rather than falling back to a hardcoded
# domain — see app/api/cron/daily-whistle/route.ts.
NEXT_PUBLIC_APP_URL=http://localhost:3000
